# Database
DATABASE_URL=postgresql+asyncpg://mynvoice:mynvoice@localhost:5432/mynvoice

# Auth
SECRET_KEY=generate-a-strong-random-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email / SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@mynvoice.app
SMTP_FROM_NAME=MYNVOICE

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Debug
DEBUG=true
